  return (
    <div style={{
      minHeight: "100vh", background: "#0a0e1a", display: "flex", flexDirection: "column",
      alignItems: "center", justifyContent: "center", color: "#fff", padding: 24, textAlign: "center",
    }}>
      <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Press+Start+2P&display=swap" rel="stylesheet" />
      <div style={{
        fontFamily: "'Press Start 2P', monospace", fontSize: "clamp(20px, 5vw, 36px)",
        color: "#FFD600", marginBottom: 8, lineHeight: 1.5, textShadow: "0 0 30px #FFD60066",
      }}>
        COOL FINANCE<br />GAMES
      </div>
      <div style={{ fontSize: 40, margin: "12px 0" }}>📈💸📉</div>
      <div style={{
        fontFamily: "'IBM Plex Mono', monospace", fontSize: 14, color: "#aaa",
        maxWidth: 420, lineHeight: 1.6, marginBottom: 24,
      }}>
        You have <span style={{ color: "#76FF03", fontWeight: 700 }}>$10,000</span> and <span style={{ color: "#FF3D71", fontWeight: 700 }}>60 seconds</span>.<br />
        Buy low. Sell high. Don't get REKT.<br />
        How much can you make?
      </div>
      <div style={{ display: "flex", flexWrap: "wrap", gap: 8, justifyContent: "center", marginBottom: 24 }}>
        {STOCKS.map(s => (
          <div key={s.symbol} style={{
            background: "rgba(255,255,255,0.05)", borderRadius: 8, padding: "8px 14px",
            border: `1px solid ${s.color}33`, fontSize: 12, fontFamily: "'IBM Plex Mono', monospace",
          }}>
            <span style={{ color: s.color, fontWeight: 700 }}>{s.symbol}</span>
            <span style={{ color: "#666", marginLeft: 6 }}>{s.volatility > 0.04 ? "🔥 High Risk" : s.volatility > 0.02 ? "⚡ Medium" : "🛡️ Safe"}</span>
          </div>
        ))}
      </div>
      <button onClick={onStart} style={{
        fontFamily: "'Press Start 2P', monospace", fontSize: 18, background: "#76FF03",
        color: "#0a0e1a", border: "none", borderRadius: 12, padding: "16px 48px",
        cursor: "pointer", letterSpacing: 2, boxShadow: "0 0 30px #76FF0344",
        transition: "transform 0.1s",
      }}
        onMouseEnter={e => e.target.style.transform = "scale(1.05)"}
        onMouseLeave={e => e.target.style.transform = "scale(1)"}
      >
        START TRADING
      </button>
    </div>
  );
}

function ResultsScreen({ stats, onRestart }) {
  const earned = BADGES.filter(b => b.check(stats));
  const grade = stats.finalValue >= STARTING_CASH * 2 ? "S" :
    stats.finalValue >= STARTING_CASH * 1.5 ? "A" :
    stats.finalValue >= STARTING_CASH * 1.2 ? "B" :
    stats.finalValue >= STARTING_CASH ? "C" :
    stats.finalValue >= STARTING_CASH * 0.7 ? "D" : "F";
  const gradeColor = { S: "#FFD600", A: "#76FF03", B: "#00E5FF", C: "#fff", D: "#FF9100", F: "#FF3D71" }[grade];

  return (
    <div style={{
      minHeight: "100vh", background: "#0a0e1a", display: "flex", flexDirection: "column",
      alignItems: "center", justifyContent: "center", color: "#fff", padding: 24, textAlign: "center",
    }}>
      <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Press+Start+2P&display=swap" rel="stylesheet" />
      <div style={{ fontFamily: "'Press Start 2P', monospace", fontSize: 14, color: "#aaa", marginBottom: 8 }}>
        MARKET CLOSED
      </div>
      <div style={{
        fontFamily: "'Press Start 2P', monospace", fontSize: 72, color: gradeColor,
        textShadow: `0 0 40px ${gradeColor}66`, margin: "8px 0",
      }}>{grade}</div>
      <div style={{
        fontSize: 28, fontWeight: 700, fontFamily: "'IBM Plex Mono', monospace",
        color: parseFloat(stats.returnPct) >= 0 ? "#76FF03" : "#FF3D71", margin: "4px 0 20px",
      }}>
        {parseFloat(stats.returnPct) >= 0 ? "+" : ""}{stats.returnPct}% return
      </div>
      <div style={{
        background: "rgba(255,255,255,0.04)", borderRadius: 12, padding: 20,
        maxWidth: 360, width: "100%", marginBottom: 20,
      }}>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, fontSize: 13, fontFamily: "'IBM Plex Mono', monospace" }}>
          <div style={{ textAlign: "left", color: "#aaa" }}>Final Value</div>
          <div style={{ textAlign: "right", fontWeight: 700 }}>${stats.finalValue.toFixed(2)}</div>
          <div style={{ textAlign: "left", color: "#aaa" }}>Trades Made</div>
          <div style={{ textAlign: "right", fontWeight: 700 }}>{stats.totalTrades}</div>
          <div style={{ textAlign: "left", color: "#aaa" }}>Stocks Traded</div>
          <div style={{ textAlign: "right", fontWeight: 700 }}>{stats.uniqueStocks}/4</div>
        </div>
      </div>
      {earned.length > 0 && (
        <div style={{ marginBottom: 24 }}>
          <div style={{ fontSize: 11, color: "#666", marginBottom: 8, fontFamily: "'Press Start 2P', monospace" }}>BADGES EARNED</div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap", justifyContent: "center" }}>
            {earned.map(b => (
              <div key={b.id} style={{
                background: "rgba(255,214,0,0.1)", border: "1px solid #FFD60033",
                borderRadius: 8, padding: "6px 12px", fontSize: 13,
              }}>
                {b.icon} {b.label}
              </div>
            ))}
          </div>
        </div>
      )}
      <button onClick={onRestart} style={{
        fontFamily: "'Press Start 2P', monospace", fontSize: 14, background: "#FFD600",
        color: "#0a0e1a", border: "none", borderRadius: 10, padding: "14px 36px",
        cursor: "pointer", letterSpacing: 1,
      }}>TRADE AGAIN</button>
    </div>
  );
}